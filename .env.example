# MSN live chat (Supabase). Copy to .env.local and fill in.

NEXT_PUBLIC_MSN_LIVE=true
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either legacy anon JWT or newer publishable key (Dashboard → API keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_MSN_OWNER_USER_ID=paste_auth_user_uuid_matching_public_users_row

# Server-only: Database → Settings → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Secret for /msn-inbox and POST /api/msn/owner/* — generate a long random string
MSN_OWNER_SECRET=your_long_random_secret
